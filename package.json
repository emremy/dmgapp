{
  "name": "dmgapp",
  "version": "1.0.1",
  "description": "Zero native dependencies, ESM-first, blazing fast macOS DMG generator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dmgapp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "test:run": "vitest --run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dmg",
    "macos",
    "disk-image",
    "appdmg",
    "installer",
    "mac",
    "darwin",
    "package",
    "distribution",
    "app",
    "application"
  ],
  "author": {
    "name": "dmgapp contributors",
    "url": "https://github.com/emremy/dmgapp"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emremy/dmgapp.git"
  },
  "bugs": {
    "url": "https://github.com/emremy/dmgapp/issues"
  },
  "homepage": "https://github.com/emremy/dmgapp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
